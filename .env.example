# Zica Bella Mobile - Environment Configuration Example
# Copy this file to .env and fill in the values

# Sentry DSN for error reporting
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# API Base URL (Production)
EXPO_PUBLIC_API_URL=https://api.zicabella.com

# Shopify Storefront Access Token
EXPO_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_token_here

# Apple Merchant ID (For Apple Pay)
EXPO_PUBLIC_APPLE_MERCHANT_ID=merchant.com.zicabella.app
