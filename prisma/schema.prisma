generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Shop {
  id                       String     @id @default(cuid())
  domain                   String     @unique
  accessToken              String
  installedAt              DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  delhiveryApiKey          String?
  razorpayKeyId            String?
  razorpayKeySecret        String?
  shiprocketEmail          String?
  shiprocketToken          String?
  webhookSecret            String?
  heroImage                String?
  heroVideo                String?
  heroTitle                String?
  heroSubtitle             String?
  heroButtonText           String?    @default("Discover")
  latestCurationTitle      String?    @default("Latest curation")
  latestCurationSubtitle   String?    @default("Season Drop")
  archiveTitle             String?    @default("The Archive")
  archiveSubtitle          String?    @default("Organic Evolution")
  blueprintTitle           String?    @default("The blueprint of Zica Bella")
  blueprintSubtitle        String?    @default("Technique & Motion")
  showHeroText             Boolean    @default(false)
  showLatestCuration       Boolean    @default(true)
  showArchive              Boolean    @default(true)
  showBlueprint            Boolean    @default(true)
  showCommunity            Boolean    @default(true)
  showProductVideo         Boolean    @default(true)
  showSizeChart            Boolean    @default(true)
  showBrand                Boolean    @default(true)
  showShippingReturn       Boolean    @default(true)
  showCare                 Boolean    @default(true)
  showSizeFit              Boolean    @default(true)
  showDetails              Boolean    @default(true)
  pdpBackground            String?
  communityTitle           String?    @default("Featured Looks")
  communitySubtitle        String?    @default("Community")
  instagramUrl             String?
  appleUrl                 String?
  spotifyUrl               String?
  youtubeUrl               String?
  featuredMedia            String?
  collectionsMedia         String?
  footerVideo              String?
  mainMenuHandle           String?
  secondaryMenuHandle      String?
  showTreeText             Boolean    @default(true)
  enabledCollectionsHeader String?
  enabledCollectionsPage   String?
  enabledCollectionsMenu   String?
  featuredMediaImage       String?
  kineticMeshProducts      String?
  spotlightTitle           String?    @default("AUTHENTIC STREETWEAR")
  spotlightSubtitle        String?    @default("Luxury Indian streetwear for modern men. Redefining bold everyday style.")
  kineticMeshTitle         String?    @default("ARCHIVE EDITION")
  flipbookConfig           String?    @default("[]")
  flipbookImage            String?
  flipbookVideo            String?
  flipbookTitle            String?    @default("Archival Vision")
  flipbookTag              String?    @default("Core Manifest")
  flipbookDesc             String?    @default("Engineered for those who move without compromise.")
  showRingCarousel         Boolean    @default(true)
  ringCarouselTitle        String?    @default("RING COLLECTION")
  ringCarouselItems        String?    @default("[]")
  communityMinOrders       Int        @default(1)
  communityAgeRestricted   Boolean    @default(true)
  communityWhatsAppEnabled Boolean    @default(true)
  chatAccessMode           String     @default("open") // "open" | "orders_only"
  customers                Customer[]
  orders                   Order[]
  products                 Product[]
}

model Customer {
  id             String    @id @default(cuid())
  shopId         String
  shopifyId      String    @unique
  email          String?
  name           String?
  phone          String?
  image          String?
  region         String?
  defaultAddress String?
  ordersCount    Int       @default(0)
  totalSpent     Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  shop           Shop      @relation(fields: [shopId], references: [id])
  orders         Order[]
  payments       Payment[]
  returns        Return[]
  communityMember CommunityMember?
  communityMessages CommunityMessage[]
  followers      Follow[]          @relation("UserFollowers")
  following      Follow[]          @relation("UserFollowing")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    Customer @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following    Customer @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Order {
  id                String      @id @default(cuid())
  shopId            String
  shopifyOrderId    String      @unique
  customerId        String
  status            String
  totalPrice        Float
  subtotalPrice     Float?
  totalTax          Float?
  currency          String      @default("INR")
  paymentStatus     String
  fulfillmentStatus String
  deliveryStatus    String      @default("pending")
  shippingAddress   String?
  billingAddress    String?
  note              String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  exchanges         Exchange[]
  customer          Customer    @relation(fields: [customerId], references: [id])
  shop              Shop        @relation(fields: [shopId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  returns           Return[]
  shipments         Shipment[]
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  shopifyLineItemId String   @unique
  productId         String?
  title             String
  quantity          Int
  price             Float
  sku               String?
  product           Product? @relation(fields: [productId], references: [id])
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Product {
  id                String      @id @default(cuid())
  shopId            String
  shopifyProductId  String      @unique
  title             String
  sku               String?
  barcode           String?
  inventoryItemId   String?     @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  newExchanges      Exchange[]  @relation("NewProduct")
  originalExchanges Exchange[]  @relation("OriginalProduct")
  inventory         Inventory[]
  orderItems        OrderItem[]
  shop              Shop        @relation(fields: [shopId], references: [id])
  returns           Return[]
}

model Inventory {
  id               String   @id @default(cuid())
  productId        String
  locationId       String
  stockQuantity    Int      @default(0)
  reservedQuantity Int      @default(0)
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

model Return {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  customerId  String
  sku         String?
  reason      String
  status      String
  requestedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Exchange {
  id                String   @id @default(cuid())
  orderId           String
  originalProductId String
  newProductId      String
  status            String
  priceDifference   Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  newProduct        Product  @relation("NewProduct", fields: [newProductId], references: [id])
  originalProduct   Product  @relation("OriginalProduct", fields: [originalProductId], references: [id])
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  customerId String
  amount     Float
  type       String
  status     String
  gateway    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Shipment {
  id             String   @id @default(cuid())
  orderId        String
  trackingNumber String?
  courier        String?
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model FeaturedUser {
  id               String   @id @default(cuid())
  orderId          String?
  name             String
  email            String
  imageUrl         String
  styleDescription String?
  isTopFeatured    Boolean  @default(false)
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  reviews          Review[]
}

model Review {
  id             String       @id @default(cuid())
  featuredUserId String
  featuredUser   FeaturedUser @relation(fields: [featuredUserId], references: [id], onDelete: Cascade)
  reviewerName   String
  rating         Int          @default(5)
  comment        String?
  status         String       @default("APPROVED")
  createdAt      DateTime     @default(now())
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // MD or HTML content
  coverImage  String?
  published   Boolean  @default(false)
  author      String   @default("Zica Bella")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityMember {
  id              String   @id @default(cuid())
  customerId      String   @unique
  customer        Customer @relation(fields: [customerId], references: [id])
  isVerified      Boolean  @default(false)
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  phone           String?
  dob             DateTime?
  whatsappOptIn   Boolean  @default(false)
  joinedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CommunityUpdate {
  id          String   @id @default(cuid())
  type        String   @default("EVENT") // EVENT, ACTIVITY, OFFER
  title       String
  description String?
  imageUrl    String?
  date        DateTime?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityMessage {
  id         String          @id @default(cuid())
  customerId String
  customer   Customer        @relation(fields: [customerId], references: [id])
  content    String
  imageUrl   String?
  createdAt  DateTime        @default(now())
  reactions  ChatReaction[]
}

model ChatReaction {
  id        String           @id @default(cuid())
  messageId String
  message   CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  customerId String
  emoji     String           @default("❤️")
  createdAt DateTime         @default(now())

  @@unique([messageId, customerId, emoji])
}

model ScanRecord {
  id           String   @id @default(cuid())
  productId    String?
  productTitle String?
  variantInfo  String?
  sku          String?
  barcode      String?
  actionType   String   // STOCK_IN, ORDER_OUT, RETURN, EXCHANGE, RTO, AUDIT
  quantity     Int      @default(1)
  beforeStock  Int?     
  afterStock   Int?
  locationId   String?
  staffName    String   @default("Admin")
  createdAt    DateTime @default(now())
}
