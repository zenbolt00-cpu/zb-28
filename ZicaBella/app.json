{
  "expo": {
    "name": "ZICA BELLA",
    "slug": "zica-bella",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zicabella",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zicabella.app",
      "appleTeamId": "NZDV3AFAEG",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Verify your identity to access your profile",
        "NSCameraUsageDescription": "Allow camera access to update your profile photo",
        "NSPhotoLibraryUsageDescription": "Allow photo library access to update your profile photo",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "plugins": [
      "expo-font",
      "expo-video",
      "expo-apple-authentication",
      "expo-local-authentication",
      [
        "expo-notifications",
        { "icon": "./assets/icon.png", "color": "#000000" }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      ["expo-build-properties", { "ios": { "useFrameworks": "static" } }]
    ]
  }
}
