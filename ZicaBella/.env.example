# Zica Bella — Environment Variables
# Copy this file to .env and fill in real values before building.

# Razorpay payment gateway key (from razorpay.com dashboard)
EXPO_PUBLIC_RAZORPAY_KEY_ID=

# App base URL
EXPO_PUBLIC_APP_URL=https://app.zicabella.com

# Replace with real Sentry DSN from sentry.io before production build.
# Leave blank to disable Sentry in development.
EXPO_PUBLIC_SENTRY_DSN=
