    "@shopify/shopify-api": "^12.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@vercel/postgres": "^0.10.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "pusher": "^5.3.2",
