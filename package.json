{
  "name": "zica-bella-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3001",
    "dev:all": "concurrently -n \"BACKEND,MOBILE\" -c \"blue,green\" \"npm run dev\" \"wait-on http://localhost:3001 && cd ZicaBella && npm start\"",
